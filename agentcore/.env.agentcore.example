# Copy to agentcore/.env.agentcore and fill values
AWS_PROFILE=aws-agent-core
AWS_REGION=eu-west-2

# From Terraform outputs
EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/customer-support-mcp-dev-agentcore-execution-role
ECR_REPOSITORY_URL=123456789012.dkr.ecr.eu-west-2.amazonaws.com/customer-support-mcp-dev-mcp-server

# Runtime image tag to deploy
IMAGE_TAG=latest

# Runtime networking and endpoint
RUNTIME_PORT=8000
RUNTIME_PATH=/mcp

# Optional naming
RUNTIME_NAME=customer-support-mcp-dev
