# Application
PORT=8000

# Backends: sqlite|dynamo and ram|sqlite|dynamo
DB_BACKEND=sqlite
MEMORY_BACKEND=ram

# AWS
AWS_REGION=eu-west-2
BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_SYSTEM_PROMPT=You are a helpful customer support assistant.

# DynamoDB table names (required only when DB_BACKEND=dynamo or MEMORY_BACKEND=dynamo)
DYNAMODB_CUSTOMERS_TABLE=customer-support-mcp-dev-customers
DYNAMODB_PRODUCTS_TABLE=customer-support-mcp-dev-products
DYNAMODB_TICKETS_TABLE=customer-support-mcp-dev-tickets
DYNAMODB_MEMORY_TABLE=customer-support-mcp-dev-memory